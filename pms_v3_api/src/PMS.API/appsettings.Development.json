{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=pms_v3;Trusted_Connection=True;Trust Server Certificate=True;Encrypt=True;"
  },
  "Jwt": {
    "Issuer": "PMS",
    "Audience": "PMS.Client",
    "SecretKey": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS_LONG",
    "AccessTokenExpireMinutes": 30,
    "RefreshTokenExpireDays": 1
  },
  "FileStorage": {
    "RootPath": "App_Data/Uploads"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  }
}